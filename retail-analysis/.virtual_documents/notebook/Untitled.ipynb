import pandas as pd
import numpy as np


df = pd.read_excel(r"C:\Users\amanr\Downloads\project\retail-analysis\data\online_retail_II.xlsx")





df.head()





df.info()














df.isnull().sum()





df = df.dropna()





df = df.drop_duplicates()





df = df[df["Quantity"] > 0]





df["Revenue"] = df["Quantity"] * df["Price"]





df.head()





df["InvoiceDate"] = pd.to_datetime(df["InvoiceDate"])

df["Year"] = df["InvoiceDate"].dt.year
df["Month"] = df["InvoiceDate"].dt.month





df.head()





total_revenue = df["Revenue"].sum()

print("Total Revenue:", total_revenue)








monthly_sales = df.groupby("Month")["Revenue"].sum()

print(monthly_sales)








top_products = df.groupby("Description")["Revenue"].sum().sort_values(ascending=False).head(10)

print(top_products)








worst_products = df.groupby("Description")["Revenue"].sum().sort_values().head(10)

print(worst_products)








country_sales = df.groupby("Country")["Revenue"].sum().sort_values(ascending=False)

print(country_sales)








top_customers = df.groupby("Customer ID")["Revenue"].sum().sort_values(ascending=False).head(10)

print(top_customers)








avg_order_value = df.groupby("Invoice")["Revenue"].sum().mean()

print("Average Order Value:", avg_order_value)






